# Dev-only connection pool tuning. Existing Cloud SQL db-f1-micro has a 25
# connection cap; backend already consumes ~12. Replica=2 * MaxOpen=3 = 6
# leaves headroom for Atlas and manual psql sessions.
ZITADEL_DATABASE_POSTGRES_MAXOPENCONNS=3
ZITADEL_DATABASE_POSTGRES_MAXIDLECONNS=1
ZITADEL_DATABASE_POSTGRES_MAXCONNLIFETIME=30m
ZITADEL_DATABASE_POSTGRES_MAXCONNIDLETIME=5m
